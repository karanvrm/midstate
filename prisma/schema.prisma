generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  STAFF
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

model User {
  id        String   @id @default(cuid())
  name      String?
  email     String   @unique
  password  String   // since Clerk is removed

  role      Role     @default(STAFF)
  status    ApprovalStatus @default(PENDING)

  image     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}