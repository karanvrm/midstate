generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                   String              @id @default(cuid())
  name                 String
  email                String              @unique
  passwordHash         String
  role                 Role                @default(STAFF)
  status               Status              @default(PENDING)
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt
  phoneNumber          String
  activatedAt          DateTime?
  assignedApplications Application[]
  attendanceRecords    AttendanceRecord[]
  Batch                Batch[]
  Candidate            Candidate[]
  taskAssignments      TaskAssignment[]
  recruiterActivities  RecruiterActivity[]
}

model JobDescriptionSheet {
  id           String   @id @default(cuid())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  companyName  String   @unique
  tableData    Json
  typeOfRoles  String
  columnWidths Json?
  rowColors    Json?
}

model AttendanceSheet {
  id        String             @id @default(cuid())
  name      String             @unique
  url       String?
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt
  records   AttendanceRecord[]
}

model AttendanceRecord {
  id        String          @id @default(cuid())
  sheetId   String
  userId    String
  day       Int
  status    String          @default("-")
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  sheet     AttendanceSheet @relation(fields: [sheetId], references: [id], onDelete: Cascade)
  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([sheetId, userId, day])
}

model Briefing {
  id           String         @id @default(cuid())
  companyName  String
  briefingText String
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  files        BriefingFile[]
  links        BriefingLink[]
}

model BriefingLink {
  id         String   @id @default(cuid())
  briefingId String
  title      String
  url        String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  briefing   Briefing @relation(fields: [briefingId], references: [id], onDelete: Cascade)

  @@index([briefingId])
}

model BriefingFile {
  id         String   @id @default(cuid())
  briefingId String
  fileName   String
  fileUrl    String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  briefing   Briefing @relation(fields: [briefingId], references: [id], onDelete: Cascade)

  @@index([briefingId])
}

model Task {
  id                   String           @id @default(cuid())
  name                 String
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt
  assignedStaffMembers TaskAssignment[]
  candidates           Candidate[]
}

model TaskAssignment {
  id        String   @id @default(cuid())
  taskId    String
  userId    String
  createdAt DateTime @default(now())
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([taskId, userId])
}

model Application {
  id                String   @id @default(cuid())
  fullName          String
  phoneNumber       String
  email             String
  preferredLocation String
  jobTitle          String
  resumeName        String
  resumeType        String
  resumeData        Bytes
  status            String   @default("Active")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  assignedToId      String?
  assignedTo        User?    @relation(fields: [assignedToId], references: [id])
}

model Batch {
  id          String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title       String
  job_title   String?
  uploaded_by String?
  uploaded_at DateTime    @default(now()) @db.Timestamptz(6)
  status      String      @default("ACTIVE")
  User        User?       @relation(fields: [uploaded_by], references: [id], onDelete: NoAction, onUpdate: NoAction)
  Candidate   Candidate[]

  @@index([uploaded_by], map: "idx_batch_uploaded_by")
}

model Candidate {
  id                  String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  batch_id            String              @db.Uuid
  assigned_to         String?
  taskId              String?
  name                String?
  email               String?
  phone               String?
  current_location    String?
  preferred_locations String?
  experience          String?
  qualification       String?
  status              String              @default("PENDING")
  remarks             String?
  selectedCompany     String?
  selectedPosition    String?
  selectedAt          DateTime?
  tenureCompleted     Boolean             @default(false)
  updated_at          DateTime            @default(now()) @db.Timestamptz(6)
  User                User?               @relation(fields: [assigned_to], references: [id], onDelete: NoAction, onUpdate: NoAction)
  Batch               Batch               @relation(fields: [batch_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  task                Task?               @relation(fields: [taskId], references: [id], onDelete: Cascade)
  recruiterActivities RecruiterActivity[]

  @@index([assigned_to], map: "idx_candidate_assigned")
  @@index([batch_id], map: "idx_candidate_batch")
  @@index([status], map: "idx_candidate_status")
  @@index([taskId])
}

enum Role {
  ADMIN
  STAFF
  OWNER
}

enum Status {
  PENDING
  ACTIVE
  REJECTED
}

model RecruiterActivity {
  id          String   @id @default(cuid())
  candidateId String   @db.Uuid
  staffId     String
  date        DateTime // Store calendar day
  status      String
  remarks     String?
  timestamp   DateTime @default(now()) @db.Timestamptz(6)

  candidate Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  staff     User      @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@index([candidateId])
  @@index([staffId])
  @@index([date])
}
